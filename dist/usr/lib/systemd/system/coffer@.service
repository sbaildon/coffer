[Unit]
Description=Encrypt and store credential

[Service]
Type=oneshot
StandardInput=socket
StandardOutput=socket
StandardError=journal
StateDirectory=coffer
DynamicUser=yes
ImportCredential=coffer.recipients.*
ImportCredential=coffer.identities.*
BindReadOnlyPaths=/usr/bin
BindReadOnlyPaths=/usr/lib64
ExecStart=/usr/local/bin/coffer.py
